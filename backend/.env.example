PORT=3001
CORS_ORIGIN=http://localhost:5173

# SMTP settings used to send contact-form emails.
# For Gmail: host=smtp.gmail.com, port=587, secure=false, and use an "App Password" (not your normal password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password

# Where contact-form messages are delivered (defaults to SMTP_USER if unset)
CONTACT_RECEIVER=your.email@gmail.com

# Admin panel (/admin on the frontend) — used to add/edit projects and publications.
# Pick a real password and a long random string for JWT_SECRET (e.g. `openssl rand -hex 32`).
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-too

# Where the SQLite database file is stored (mounted as a Docker volume in production).
DB_PATH=./data/portfolio.db
